<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import java.lang.String?>

<AnchorPane prefHeight="768.0" prefWidth="1024.0" styleClass="editor-root" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="StarVault.galaxymemory.StarEditorController">
   <children>
      <Button fx:id="closeEditorButton" mnemonicParsing="false" styleClass="close-x-button" text="✕" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="16.0" />

      <HBox layoutX="50.0" layoutY="50.0" prefHeight="668.0" prefWidth="924.0" spacing="50.0" AnchorPane.bottomAnchor="50.0" AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0" AnchorPane.topAnchor="56.0">
         <children>
            <!-- Left column: star preview + stats -->
            <VBox alignment="CENTER" prefWidth="300.0" spacing="20.0">
               <children>
                  <StackPane fx:id="starIconContainer" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="250.0" prefWidth="250.0">
                     <styleClass>
                        <String fx:value="carousel-container" />
                     </styleClass>
                     <children>
                        <StackPane fx:id="starPreviewHolder" prefHeight="200.0" prefWidth="200.0" />
                     </children>
                  </StackPane>

                  <HBox alignment="CENTER" spacing="15.0">
                     <children>
                        <Button fx:id="starPrevButton" mnemonicParsing="false" styleClass="accent-button" text="&lt;" />
                        <HBox alignment="CENTER" spacing="5.0">
                           <children>
                              <Label fx:id="starPaginationText" styleClass="text-label" text="1/3" />
                           </children>
                        </HBox>
                        <Button fx:id="starNextButton" mnemonicParsing="false" styleClass="accent-button" text="&gt;" />
                     </children>
                  </HBox>

                  <HBox alignment="CENTER" spacing="10.0">
                     <children>
                        <Label styleClass="text-label" text="Word Count:" />
                        <Label fx:id="wordCountLabel" styleClass="title-label" text="0" />
                     </children>
                  </HBox>

                  <VBox alignment="CENTER_LEFT" prefWidth="100.0">
                     <children>
                        <Label styleClass="text-label" text="Star phase (color):">
                           <font>
                              <Font name="System Bold" size="12.0" />
                           </font>
                        </Label>
                        <Label fx:id="starPhaseLabel" alignment="CENTER" maxWidth="1.7976931348623157E308" prefHeight="30.0" styleClass="text-label" text="O (Blue)">
                           <padding>
                              <Insets left="10.0" right="10.0" />
                           </padding>
                           <VBox.margin>
                              <Insets top="5.0" />
                           </VBox.margin>
                        </Label>
                        <Region fx:id="phaseColorSwatch" styleClass="phase-color-swatch">
                           <VBox.margin>
                              <Insets top="10.0" />
                           </VBox.margin>
                        </Region>
                     </children>
                  </VBox>
               </children>
            </VBox>

            <!-- Right column: title, memory, photos -->
            <VBox prefWidth="574.0" spacing="16.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="title-label" text="Title:" />
                  <TextField fx:id="starTitleField" prefHeight="40.0" promptText="Name this memory" styleClass="accent-input" />

                  <Label styleClass="title-label" text="Memory:" />
                  <TextArea fx:id="starMemoryText" prefHeight="200.0" prefWidth="200.0" promptText="Write here — color shifts every 500 words toward white." styleClass="memo-textarea" wrapText="true" VBox.vgrow="ALWAYS" />

                  <!-- Photos section -->
                  <HBox alignment="CENTER_LEFT" spacing="12.0">
                     <children>
                        <Label styleClass="title-label" text="Photos:" />
                        <Button fx:id="addPhotoButton" mnemonicParsing="false" styleClass="accent-button" text="＋ Add Photo" />
                     </children>
                  </HBox>

                  <!-- Scrollable photo strip -->
                  <ScrollPane fx:id="photoScrollPane" fitToHeight="true" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER" prefHeight="110.0" styleClass="photo-scroll-pane">
                     <content>
                        <HBox fx:id="photoStrip" alignment="CENTER_LEFT" spacing="10.0" prefHeight="100.0">
                           <padding>
                              <Insets left="8.0" right="8.0" top="4.0" bottom="4.0" />
                           </padding>
                        </HBox>
                     </content>
                  </ScrollPane>

                  <HBox alignment="CENTER_RIGHT" prefHeight="50.0" prefWidth="200.0" spacing="20.0">
                     <children>
                        <Button fx:id="saveStarButton" mnemonicParsing="false" styleClass="accent-button" text="Save &amp; Close" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</AnchorPane>
